<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- Android Go biasanya tidak punya banyak RAM, tapi permission ini tidak menambah beban -->

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.GoGoLive"
        android:usesCleartextTraffic="false">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.GoGoLive.Splash"
            android:launchMode="singleTop"
            android:configChanges="orientation|screenSize|keyboardHidden">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
          Service ini yang benar-benar melakukan capture layar + streaming.
          Berjalan sebagai FOREGROUND SERVICE BIASA (bukan bubble/overlay),
          jadi tidak menggambar apapun di atas aplikasi lain - hanya notifikasi
          persisten di status bar seperti yang diwajibkan Android untuk
          MediaProjection berjalan di background.
        -->
        <service
            android:name=".service.ScreenRecordService"
            android:exported="false"
            android:foregroundServiceType="mediaProjection|microphone" />

    </application>
</manifest>
